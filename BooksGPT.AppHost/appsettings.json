{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning", // Log warnings or higher from ASP.NET Core framework
            "MyMvcApp.Controllers.HomeController": "Information" // Specific level for your controller
        },
        "Console": { // Optional: Enable Console logging
            "IncludeScopes": false,
            "FormatterName": "json",
            "FormatterOptions": {
                "JsonWriterOptions": {
                    "Indented": true
                }
            }
        },
        "Debug": { // Optional: Enable Debug output logging
            "LogLevel": {
                "Default": "Trace"
            }
        }
    },
    "AllowedHosts": "*",
    "ApiKeys": {
        "Gemini": "",
        "GoogleBooks": ""
    }
}
