@{
    ViewData["Title"] = "Home Page";
    Layout = "_Layout";
}

@{
    var isLogin = Context.Request.Cookies["isLogin"];
    var currentChatIdFromSession = Context.Session.GetString("CurrentChatId") ?? "";
    var cookieName = Context.Request.Cookies["name"] ?? "";
    var cookieAvatar = Context.Request.Cookies["avatarColor"] ?? "";
    var avatarInitial = string.IsNullOrWhiteSpace(cookieName) ? "U" : cookieName.Substring(0,1).ToUpper();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>BooksGPT</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/home/index.css" />
</head>
<body>
    <main role="main" class="chat-wrapper">
        <div class="chat-history">
            <div style="display:flex;align-items:center;justify-content:space-between;">
                <h2 style="margin:0;">Chat History</h2>
                <button id="new-chat-btn" title="New chat" style="background:#10a37f;border:none;color:#061e15;font-weight:700;padding:6px 10px;border-radius:8px;cursor:pointer;">+</button>
            </div>

            <div class="history-list" style="overflow-y:auto;flex:1;padding-right:6px;margin-top:8px;">
                @if (isLogin == null || isLogin.ToLower() != "true")
                {
                    <div class="login-prompt">
                        <p>Please <a href="/login">login</a> in order to view your chat history.</p>
                    </div>
                }
                else
                {
                    var chatHistory = ViewBag.ChatHistory as List<BooksGPT.Models.ChatHistoryModel>;
                    if (chatHistory != null && chatHistory.Count > 0)
                    {
                        foreach (var item in chatHistory)
                        {
                            var isActive = !string.IsNullOrEmpty(currentChatIdFromSession) && item.Id.ToString() == currentChatIdFromSession;
                            <div class="history-item@(isActive ? " active" : "")" data-id="@item.Id">
                                <div class="history-title" style="flex:1;cursor:pointer;">@item.Title</div>
                                <div style="margin-left:8px;position:relative;">
                                    <button class="history-menu-btn" style="background:transparent;border:none;color:#9ca3af;cursor:pointer;padding:4px 6px;">⋯</button>
                                    <div class="history-menu" style="display:none;position:absolute;right:0;bottom:28px;background:#0b0b0b;padding:6px;border-radius:8px;box-shadow:0 8px 20px rgba(0,0,0,0.6);z-index:1200;">
                                        <button class="delete-chat" style="background:transparent;border:none;color:#fff;cursor:pointer;padding:6px 8px;">Delete</button>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="history-item" style="color:#aaa;">No chat history found.</div>
                    }
                }
            </div>

            <!-- Bottom user panel inside left sidebar -->
            <div style="padding:12px;border-top:1px solid #222;margin-top:8px;">
                <div id="left-user-panel" style="display:flex;align-items:center;justify-content:space-between;gap:12px;">
                    <div style="display:flex;align-items:center;gap:12px;">
                        <div id="left-avatar" style="width:40px;height:40px;border-radius:50%;background:@(string.IsNullOrWhiteSpace(cookieAvatar) ? "#6b7280" : cookieAvatar);display:flex;align-items:center;justify-content:center;font-weight:600;color:#fff;font-size:16px;">@avatarInitial</div>
                        <div>
                            <div id="left-user-name" style="font-size:14px;color:#e5e7eb;">@(string.IsNullOrWhiteSpace(cookieName) ? "Guest" : cookieName)</div>
                            <div style="font-size:12px;color:#9ca3af;">Profile & settings</div>
                        </div>
                    </div>
                    <div>
                        <button id="left-user-toggle" style="background:transparent;border:none;color:#9ca3af;cursor:pointer;">⋯</button>
                    </div>
                </div>
                <div id="left-user-menu" style="display:none;background:#0b0b0b;color:#fff;padding:8px;border-radius:8px;box-shadow:0 8px 30px rgba(0,0,0,0.6);">
                    <div style="margin-bottom:8px;"><a href="#" id="left-edit-profile" style="color:#fff;text-decoration:none;">Edit profile</a></div>
                    <div><a href="#" id="left-logout-link" style="color:#fff;text-decoration:none;">Logout</a></div>
                </div>
            </div>
        </div>

        <div class="chat-content">
            <div class="chat-header">
                <button id="mobile-sidebar-btn" title="Menu" style="position:absolute;left:14px;top:50%;transform:translateY(-50%);background:transparent;border:none;color:#fff;font-size:22px;cursor:pointer;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                </button>
                <h1>BooksGPT</h1>
                <p style="color: #aaa;">Ask me anything about any book!</p>
            </div>

            <!-- Mobile Sidebar Overlay -->
            <div id="mobile-sidebar-overlay" class="mobile-sidebar-overlay"></div>
            <div id="mobile-sidebar" class="mobile-sidebar">
                <div class="mobile-sidebar-header">
                    <button id="mobile-new-chat-btn" class="mobile-new-chat-btn" title="New chat">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                        New chat
                    </button>
                    <button id="mobile-sidebar-close" class="mobile-sidebar-close" title="Close sidebar">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </button>
                </div>

                <div class="mobile-sidebar-list">
                    @if (isLogin == null || isLogin.ToLower() != "true")
                    {
                        <div class="mobile-login-prompt">
                            <p>Please <a href="/login">login</a> to view your chat history.</p>
                        </div>
                    }
                    else
                    {
                        var mobileChatHistory = ViewBag.ChatHistory as List<BooksGPT.Models.ChatHistoryModel>;
                        if (mobileChatHistory != null && mobileChatHistory.Count > 0)
                        {
                            foreach (var item in mobileChatHistory)
                            {
                                var isActive = !string.IsNullOrEmpty(currentChatIdFromSession) && item.Id.ToString() == currentChatIdFromSession;
                                <div class="history-item@(isActive ? " active" : "")" data-id="@item.Id">
                                    <div class="history-title" style="flex:1;cursor:pointer;">@item.Title</div>
                                    <div style="margin-left:8px;position:relative;">
                                        <button class="history-menu-btn" style="background:transparent;border:none;color:#9ca3af;cursor:pointer;padding:4px 6px;">⋯</button>
                                        <div class="history-menu" style="display:none;position:absolute;right:0;bottom:28px;background:#0b0b0b;padding:6px;border-radius:8px;box-shadow:0 8px 20px rgba(0,0,0,0.6);z-index:1200;">
                                            <button class="delete-chat" style="background:transparent;border:none;color:#fff;cursor:pointer;padding:6px 8px;">Delete</button>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="history-item" style="color:#aaa;">No chat history found.</div>
                        }
                    }
                </div>

                <!-- Mobile user panel -->
                <div class="mobile-sidebar-user">
                    <div id="mobile-user-panel" style="display:flex;align-items:center;justify-content:space-between;gap:12px;">
                        <div style="display:flex;align-items:center;gap:12px;">
                            <div id="mobile-avatar" style="width:36px;height:36px;border-radius:50%;background:@(string.IsNullOrWhiteSpace(cookieAvatar) ? "#6b7280" : cookieAvatar);display:flex;align-items:center;justify-content:center;font-weight:600;color:#fff;font-size:14px;">@avatarInitial</div>
                            <div>
                                <div id="mobile-user-name" style="font-size:14px;color:#e5e7eb;">@(string.IsNullOrWhiteSpace(cookieName) ? "Guest" : cookieName)</div>
                                <div style="font-size:11px;color:#9ca3af;">Profile & settings</div>
                            </div>
                        </div>
                        <button id="mobile-user-toggle" style="background:transparent;border:none;color:#9ca3af;cursor:pointer;">⋯</button>
                    </div>
                    <div id="mobile-user-menu" style="display:none;background:#0b0b0b;color:#fff;padding:8px;border-radius:8px;box-shadow:0 8px 30px rgba(0,0,0,0.6);position:absolute;bottom:70px;left:12px;right:12px;z-index:1500;">
                        <div style="margin-bottom:8px;"><a href="#" class="mobile-edit-profile" style="color:#fff;text-decoration:none;">Edit profile</a></div>
                        <div><a href="#" class="mobile-logout-link" style="color:#fff;text-decoration:none;">Logout</a></div>
                    </div>
                </div>
            </div>

            <div id="chat-box" class="chat-box">
                <script type="text/javascript">
                    window.currentChatIdFromServer = '@currentChatIdFromSession';
                </script>
                @if (ViewBag.IsReload == true)
                {
                    <script type="text/javascript">
                        window.chatReloadData = {
                            userQuestions: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.UserQuestions ?? new List<string>())),
                            botAnswers: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.BotAnswers ?? new List<string>())),
                            currentChatId: '@currentChatIdFromSession'
                        };
                    </script>
                }
                else if (ViewBag.AIReply != null)
                {
                    <div class="message bot-message">@ViewBag.AIReply</div>
                }
            </div>

            <div class="input-area">
                <textarea id="user-input" placeholder="Type your message..." autocomplete="off" rows="1"></textarea>
                <button id="send-button" type="submit">Send</button>
            </div>
        </div>
    </main>

    <!-- Edit Profile Modal -->
    <div id="edit-profile-modal" class="modal-overlay" style="display:none;">
        <div class="modal-box" role="dialog" aria-modal="true">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">
                <h3 style="margin:0;font-size:16px;color:#e5e7eb;">Edit profile</h3>
                <button id="modal-close" style="background:transparent;border:none;color:#9ca3af;font-size:18px;cursor:pointer;">✕</button>
            </div>
            <div class="modal-row">
                <label for="profile-name">Display name</label>
                <input id="profile-name" type="text" />
            </div>
            <div class="modal-row">
                <label for="profile-username">Username</label>
                <input id="profile-username" type="text" />
            </div>
            <div class="modal-row">
                <label for="profile-color">Avatar color</label>
                <input id="profile-color" type="color" />
            </div>
            <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:6px;">
                <button id="modal-cancel" style="background:transparent;border:1px solid #333;padding:8px 12px;border-radius:8px;color:#fff;">Cancel</button>
                <button id="modal-save" style="background:#10a37f;border:none;padding:8px 12px;border-radius:8px;color:#061e15;">Save</button>
            </div>
        </div>
    </div>
</body>
</html>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/home/index.js"></script>

    @{
        var isLoginCookieForPopup = Context.Request.Cookies["isLogin"] ?? "";
        var showLoginSuccessOnHome = TempData["LoginSuccess"] != null && !string.IsNullOrEmpty(isLoginCookieForPopup) && isLoginCookieForPopup.ToLower() == "true";
    }
    @if (showLoginSuccessOnHome)
    {
        <text>
            <script>
                Swal.fire({
                    title: 'Login Successful',
                    text: 'Press ok to start learning',
                    icon: 'success',
                    background: '#18181b',
                    color: '#fff',
                    iconColor: '#22c55e',
                    confirmButtonText: 'Ok',
                    customClass: {
                        popup: 'rounded-2xl shadow-lg',
                        confirmButton: 'bg-green-500 hover:bg-green-600 text-white font-medium px-6 py-2 rounded-lg focus:outline-none'
                    }
                });
            </script>
        </text>
    }
}
